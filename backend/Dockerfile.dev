FROM node:20-alpine

# Activa pnpm y configura corepack
RUN corepack enable && corepack prepare pnpm@latest --activate

# Instala algunas utilidades útiles para desarrollo
RUN apk add --no-cache bash

# Directorio de trabajo
WORKDIR /app

# Copia solo archivos necesarios para instalar dependencias
COPY package.json pnpm-lock.yaml tsconfig.json ./

# Instala dependencias
RUN pnpm install

# Copia el resto del proyecto (excepto lo ignorado por .dockerignore)
COPY . .

# Expone el puerto de la API
EXPOSE 3000

# Comando por defecto: inicia en modo desarrollo
CMD ["pnpm", "dev"]
